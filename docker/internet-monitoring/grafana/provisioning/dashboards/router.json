      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PAAD2532CB637A21E"
          },
          "editorMode": "code",
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{job=\"prometheus-router\",mode=\"idle\"}[5m])) * 100)",
          "instant": false,
          "legendFormat": "CPU Usage",
          "range": true,
          "refId": "CPU Usage"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PAAD2532CB637A21E"
          },
          "editorMode": "code",
          "expr": "(1 - (node_memory_free_bytes{job=\"prometheus-router\"} / node_memory_size_bytes{job=\"prometheus-router\"})) * 100",
          "instant": false,
          "legendFormat": "MEM Usage",
          "range": true,
          "refId": "MEM Usage"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PAAD2532CB637A21E"
          },
          "editorMode": "code",
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",job=\"prometheus-router\"} / node_filesystem_size_bytes{mountpoint=\"/\",job=\"prometheus-router\"})) * 100",
          "instant": false,
          "legendFormat": "Disk Usage",
          "range": true,
          "refId": "Disk Usage"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PAAD2532CB637A21E"
          },
          "editorMode": "code",
          "expr": "(rate(node_network_receive_bytes_total{job=\"prometheus-router\",device=\"re0\"}[5m]) * 8) / 1000000000 * 100",
          "instant": false,
          "legendFormat": "Network Utilization (Incoming)",
          "range": true,
          "refId": "Network Utilization (Incoming)"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PAAD2532CB637A21E"
          },
          "editorMode": "code",
          "expr": "(rate(node_network_transmit_bytes_total{job=\"prometheus-router\",device=\"re1\"}[5m]) * 8) / 1000000000 * 100",
          "instant": false,
          "legendFormat": "Network Utilization (Outgoing)",
          "range": true,
          "refId": "Network Utilization (Outgoing)"
        }
      ],
      "title": "",
      "transparent": true,
      "type": "gauge"
    },
